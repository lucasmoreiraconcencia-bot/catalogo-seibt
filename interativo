function fmt(v) {
  if (!v || isNaN(Number(v)) || Number(v) === 0) return "—";
  return "R$ " + Number(v).toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
}

let currentFilter = "TODOS";
let currentTab = "cards";

function getLine(modelo) {
  const m = modelo.toUpperCase().trim();

  // Periféricos
  if (m.startsWith('EXAUSTOR') || m.startsWith('SILO') || m.startsWith('CABINE') || m.startsWith('SOFT STARTER')) return 'PERIFERICOS';

  // Equipamentos identificados pelo prefixo isolado
  if (/^TPS\b/.test(m)) return 'TPS';
  if (/^TS\b/.test(m))  return 'TS';
  if (/^MDTS\b/.test(m)) return 'MDTS';
  if (/^MHTS\b/.test(m)) return 'MHTS';
  if (/^ETS\b/.test(m) || /^ESTS\b/.test(m)) return 'TP';
  if (/^ES\b/.test(m))  return 'ES';
  if (/^PS\b/.test(m))  return 'PS';
  if (/^AS\b/.test(m))  return 'AS';
  if (/^SPS\b/.test(m)) return 'SPS';
  if (/^SFS\b/.test(m)) return 'SFS';
  if (/^TP\b/.test(m))  return 'MHTS';
  if (m.startsWith('GUILHOTINA')) return 'GUILHOTINA';

  // Linhas de moinho MGHS
  if (m.includes('BSC') && m.includes('BR')) return 'BSC BR';
  if (m.includes('BSC')) return 'BSC';
  if (m.includes('LRX')) return 'LRX';
  if (m.includes('LR'))  return 'LR';
  if (m.includes('RCX')) return 'RCX';
  if (m.includes('TFV')) return 'TFV';
  if (m.includes('A2'))  return 'A2';
  if (/\bN$/.test(m))   return 'N';
  if (/\bE$/.test(m))   return 'E';
  if (/\bA$/.test(m))   return 'A';

  return 'OUTROS';
}

function getFiltered() {
  const q = document.getElementById('search').value.toLowerCase();
  return MACHINES.filter(m => {
    const line = getLine(m.modelo);
    if (currentFilter !== "TODOS" && line !== currentFilter) return false;
    if (q && !(m.modelo + ' ' + m.descricao).toLowerCase().includes(q)) return false;
    return true;
  });
}

function findSpecs(modelo) {
  for (const k in SPECS) {
    const clean = modelo.replace('MGHS ', '').trim();
    if (k.includes(clean)) return SPECS[k];
  }
  return null;
}

function openSpecsModal(modelo) {
  const sp = findSpecs(modelo);
  if (!sp) return;
  
  document.getElementById('modalTitle').innerText = 'Especificações: ' + modelo;
  
  let html = '<table class="modal-table"><tbody>';
  for (const [key, val] of Object.entries(sp)) {
    html += '<tr><th>' + key + '</th><td>' + val + '</td></tr>';
  }
  html += '</tbody></table>';
  
  document.getElementById('modalBody').innerHTML = html;
  
  const modal = document.getElementById('specsModal');
  modal.style.display = 'flex';
  setTimeout(() => modal.classList.add('active'), 10);
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  const modal = document.getElementById('specsModal');
  modal.classList.remove('active');
  setTimeout(() => {
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }, 200);
}

function renderStats(items) {
  const vals = items.map(m => m.valor_maq || 0).filter(v => v > 0);
  const families = new Set(items.map(m => m.modelo));
  document.getElementById('statsBar').innerHTML = 
    '<div class="stat-card"><div class="num">' + items.length + '</div><div class="label">Equipamentos</div></div>' +
    '<div class="stat-card"><div class="num">' + families.size + '</div><div class="label">Modelos</div></div>' +
    '<div class="stat-card"><div class="num">' + (vals.length ? fmt(Math.min(...vals)) : '—') + '</div><div class="label">A partir de</div></div>' +
    '<div class="stat-card"><div class="num">' + (vals.length ? fmt(Math.max(...vals)) : '—') + '</div><div class="label">Até</div></div>';
}

function renderCards(items) {
  const grid = document.getElementById('cardsView');
  if (!items.length) {
    grid.innerHTML = '<div class="empty-state"><div class="icon">&#128270;</div><p>Nenhum equipamento encontrado.</p></div>';
    return;
  }
  grid.innerHTML = items.map(m => {
    const line = getLine(m.modelo);
    const vm = m.valor_maq || 0;
    const p220 = m.valor_p220 || 0;
    const p380 = m.valor_p380 || 0;
    const t220 = vm + p220;
    const t380 = vm + p380;
    const sp = findSpecs(m.modelo);

    let btnSpecsHTML = '';
    if (sp) {
      const safeModelo = m.modelo.replace(/'/g, "\\'");
      btnSpecsHTML = '<button class="btn-specs" onclick="openSpecsModal(\'' + safeModelo + '\')">&#128269; Ver Especificações Técnicas</button>';
    }

    let imgHTML = '<div class="card-img-container">';
    if (m.imagem) {
      imgHTML += '<img src="' + m.imagem + '" class="card-img" alt="' + m.modelo + '" onerror="this.onerror=null; this.parentElement.innerHTML=\'<div class=\\\'placeholder-icon\\\'>&#128247;</div>\';">';
    } else {
      imgHTML += '<div class="placeholder-icon">&#128247;</div>';
    }
    imgHTML += '</div>';

    const hasPanelInfo = (p220 > 0 || p380 > 0);
    
    let baseLabel, shortLabel;
    const mu = m.modelo.toUpperCase();
    const psMatch = mu.match(/\bPS\s*(\d+)\b/);
    const asMatch = mu.match(/\bAS\s*(\d+)\b/);

    if (psMatch && +psMatch[1] >= 50 && +psMatch[1] <= 220) {
      baseLabel = 'Valor Picotadora';  shortLabel = 'Picotadora';
    } else if (asMatch && +asMatch[1] >= 500 && +asMatch[1] <= 1500) {
      baseLabel = 'Valor Aglutinador'; shortLabel = 'Aglutinador';
    } else if (mu.includes('SPS')) {
      baseLabel = 'Valor SPS';         shortLabel = 'SPS';
    } else if (mu.includes('SFS')) {
      baseLabel = 'Valor SFS';         shortLabel = 'SFS';
    } else if (mu.includes('GUILHOTINA')) {
      baseLabel = 'Valor Guilhotina';  shortLabel = 'Guilhotina';
    } else if (mu.includes('EXAUSTOR')) {
      baseLabel = 'Valor VCS';         shortLabel = 'VCS';
    } else if (mu.startsWith('ES ')) {
      baseLabel = 'Valor Extrusora';   shortLabel = 'Extrusora';
    } else {
      baseLabel = 'Valor Moinho';      shortLabel = 'Moinho';
    }

    const isExaustor = mu.includes('EXAUSTOR');
    let labelP220 = isExaustor ? 'Painel Compartilhado' : 'Painel NR12 (220V)';
    let labelP380 = isExaustor ? 'Painel Dedicado' : 'Painel NR12 (380V)';
    let labelTotal220 = isExaustor ? 'VCS + Painel Compartilhado' : 'Conjunto Completo (' + shortLabel + ' + Painel NR12 220V)';
    let labelTotal380 = isExaustor ? 'VCS + Painel Dedicado'      : 'Conjunto Completo (' + shortLabel + ' + Painel NR12 380V)';
    
    let priceHTML = '<div class="price-grid">';
    priceHTML += '<div class="price-item full highlight"><div class="p-label">' + baseLabel + '</div><div class="p-value">' + fmt(vm) + '</div></div>';
    
    if (hasPanelInfo) {
      if (p220 > 0) priceHTML += '<div class="price-item"><div class="p-label">' + labelP220 + '</div><div class="p-value">' + fmt(p220) + '</div></div>';
      if (p380 > 0) priceHTML += '<div class="price-item"><div class="p-label">' + labelP380 + '</div><div class="p-value">' + fmt(p380) + '</div></div>';
      priceHTML += '</div>';

      let totalsHTML = '<div class="totals-row">';
      if (p220 > 0) totalsHTML += '<div class="total-item"><div class="t-label">' + labelTotal220 + '</div><div class="t-value">' + fmt(t220) + '</div></div>';
      if (p380 > 0) totalsHTML += '<div class="total-item alt"><div class="t-label">' + labelTotal380 + '</div><div class="t-value">' + fmt(t380) + '</div></div>';
      totalsHTML += '</div>';
      
      return '<div class="product-card">' +
        '<div class="card-header"><span class="card-modelo">' + m.modelo + '</span><span class="card-linha">' + line + '</span></div>' +
        imgHTML +
        '<div class="card-body">' +
          '<div class="card-desc">' + m.descricao + '</div>' +
          priceHTML + totalsHTML + btnSpecsHTML +
        '</div></div>';
    } else {
      priceHTML += '<div class="price-item muted full"><div class="p-label">Painel NR12</div><div class="p-value">Valor não cadastrado / Consultar</div></div></div>';
      return '<div class="product-card">' +
        '<div class="card-header"><span class="card-modelo">' + m.modelo + '</span><span class="card-linha">' + line + '</span></div>' +
        imgHTML +
        '<div class="card-body">' +
          '<div class="card-desc">' + m.descricao + '</div>' +
          priceHTML + btnSpecsHTML +
        '</div></div>';
    }
  }).join('');
}

function renderTable(items) {
  document.getElementById('tableView').innerHTML = '<table><thead><tr>' +
    '<th>Modelo</th><th>Descrição</th><th>Valor Equip. (R$)</th><th>Painel 220V</th><th>Painel 380V</th><th>Total (+ 220V)</th><th>Total (+ 380V)</th>' +
    '</tr></thead><tbody>' +
    items.map(function(m) {
      const vm = m.valor_maq||0, p2=m.valor_p220||0, p3=m.valor_p380||0;
      return '<tr><td><strong>' + m.modelo + '</strong></td><td>' + m.descricao + '</td>' +
        '<td class="money">' + fmt(vm) + '</td>' +
        '<td class="money">' + fmt(p2) + '</td>' +
        '<td class="money">' + fmt(p3) + '</td>' +
        '<td class="money accent">' + (p2 ? fmt(vm+p2) : '—') + '</td>' +
        '<td class="money accent">' + (p3 ? fmt(vm+p3) : '—') + '</td></tr>';
    }).join('') + '</tbody></table>';
}

function renderNavalhas() {
  const q = document.getElementById('search').value.toLowerCase();
  const filtered = NAVALHAS.filter(n => !q || n.modelo.toLowerCase().includes(q) || (n.cod_fixa && String(n.cod_fixa).toLowerCase().includes(q)) || (n.cod_rot && String(n.cod_rot).toLowerCase().includes(q)));

  const body = filtered.length ? filtered.map(function(n) {
      const codFixa = (n.cod_fixa && String(n.cod_fixa).trim() && n.cod_fixa !== '/') ? n.cod_fixa : '-';
      const codRot  = (n.cod_rot  && String(n.cod_rot).trim()  && n.cod_rot  !== '/') ? n.cod_rot  : '-';
      return '<tr><td><strong>' + n.modelo + '</strong></td>' +
        '<td style="text-align:center">' + codFixa + '</td>' +
        '<td style="text-align:center">' + (n.qtde_fixa||'') + '</td>' +
        '<td class="money">' + fmt(n.valor_fixa) + '</td>' +
        '<td style="text-align:center">' + codRot + '</td>' +
        '<td style="text-align:center">' + (n.qtde_rot||'') + '</td>' +
        '<td class="money">' + fmt(n.valor_rot) + '</td>' +
        '<td class="money accent">' + fmt(n.total) + '</td></tr>';
    }).join('') : '<tr><td colspan="8" style="text-align:center; padding: 2rem; color:var(--text-muted)">Nenhum item encontrado.</td></tr>';

  document.getElementById('section-navalhas').innerHTML = '<h2 class="section-title">Navalhas — Peças de Reposição<span class="count-badge">' + filtered.length + '</span></h2>' +
    '<div class="table-view" style="display:block"><table><thead><tr>' +
    '<th>Modelo</th><th style="text-align:center">CÓD. FIXA</th><th style="text-align:center">Qtd Fixa</th><th>Valor Unit. Fixa</th><th style="text-align:center">CÓD. ROTORA</th><th style="text-align:center">Qtd Rotora</th><th>Valor Unit. Rotora</th><th>Total Jogo</th>' +
    '</tr></thead><tbody>' + body + '</tbody></table></div>';
}

function renderPeneiras() {
  const q = document.getElementById('search').value.toLowerCase();
  const filtered = PENEIRAS.filter(p => !q || p.modelo.toLowerCase().includes(q) || (p.furos_codigos && p.furos_codigos.toLowerCase().includes(q)));

  const body = filtered.length ? filtered.map(function(p) {
      const furos = p.furos_codigos || '—';
      return '<tr><td><strong>' + p.modelo + '</strong></td>' +
        '<td class="money">' + fmt(p.valor) + '</td>' +
        '<td style="text-align:center">' + p.ipi + '</td>' +
        '<td class="money accent">' + fmt(p.total) + '</td>' +
        '<td style="font-size: 0.78rem; color: var(--text-muted); line-height: 1.5;">' + furos + '</td></tr>';
    }).join('') : '<tr><td colspan="5" style="text-align:center; padding: 2rem; color:var(--text-muted)">Nenhum item encontrado.</td></tr>';

  document.getElementById('section-peneiras').innerHTML = '<h2 class="section-title">Peneiras — Peças de Reposição<span class="count-badge">' + filtered.length + '</span></h2>' +
    '<div class="table-view" style="display:block"><table><thead><tr>' +
    '<th>Modelo</th><th>Valor Base</th><th style="text-align:center">IPI</th><th>Total (Base + IPI)</th><th>Diâmetros e Códigos Disponíveis</th>' +
    '</tr></thead><tbody>' + body + '</tbody></table></div>' +
    '<p style="color: var(--text-muted); font-size: 0.8rem; margin-top: 1rem; text-align: center;">* PENEIRAS: Diâmetros especiais fora do padrão acrescentar 75% ao preço. Furo quadrado acrescentar +50%.</p>';
}

function renderReciclagem() {
  const q = document.getElementById('search').value.toLowerCase();
  const filtered = RECICLAGEM.filter(r => !q || r.equipamento.toLowerCase().includes(q) || (r.potencia && String(r.potencia).toLowerCase().includes(q)));

  const body = filtered.length ? filtered.map(function(r) {
      return '<tr><td>' + r.equipamento + '</td><td style="text-align:center">' + r.potencia + '</td><td class="money" style="font-weight:600">' + fmt(r.valor) + '</td></tr>';
    }).join('') : '<tr><td colspan="3" style="text-align:center; padding: 2rem; color:var(--text-muted)">Nenhum item encontrado.</td></tr>';

  document.getElementById('section-reciclagem').innerHTML = '<h2 class="section-title">Equipamentos de Reciclagem<span class="count-badge">' + filtered.length + '</span></h2>' +
    '<div class="table-view" style="display:block"><table><thead><tr>' +
    '<th>Equipamento</th><th style="text-align:center">Potência</th><th>Valor (R$)</th>' +
    '</tr></thead><tbody>' + body + '</tbody></table></div>';
}

function renderLinhasPEPP() {
  const q = document.getElementById('search').value.toLowerCase();
  const filtered = LINHAS_PEPP.filter(l => !q || l.categoria.toLowerCase().includes(q) || l.capacidade.toLowerCase().includes(q));

  const body = filtered.length ? filtered.map(function(l) {
      return '<tr><td><strong>' + l.categoria + '</strong></td><td style="text-align:center">' + l.capacidade + '</td><td class="money accent">' + fmt(l.valor) + '</td></tr>';
    }).join('') : '<tr><td colspan="3" style="text-align:center; padding: 2rem; color:var(--text-muted)">Nenhum item encontrado.</td></tr>';

  document.getElementById('section-linhas-pepp').innerHTML = '<h2 class="section-title">Linhas Completas PE/PP<span class="count-badge">' + filtered.length + '</span></h2>' +
    '<div class="table-view" style="display:block"><table><thead><tr>' +
    '<th>Categoria / Tipo</th><th style="text-align:center">Capacidade Produtiva</th><th>Valor Médio (R$)</th>' +
    '</tr></thead><tbody>' + body + '</tbody></table></div>';
}

function render() {
  const items = getFiltered();
  renderStats(items);
  renderCards(items);
  renderTable(items);
  
  renderNavalhas();
  renderPeneiras();
  renderReciclagem();
  renderLinhasPEPP();
  
  document.getElementById('cardsView').style.display = (currentTab === 'cards') ? 'grid' : 'none';
  document.getElementById('tableView').style.display = (currentTab === 'table') ? 'block' : 'none';
  document.getElementById('section-machines').style.display = ['cards','table'].includes(currentTab) ? 'block' : 'none';
  document.getElementById('section-navalhas').style.display = (currentTab === 'navalhas') ? 'block' : 'none';
  document.getElementById('section-peneiras').style.display = (currentTab === 'peneiras') ? 'block' : 'none';
  document.getElementById('section-reciclagem').style.display = (currentTab === 'reciclagem') ? 'block' : 'none';
  document.getElementById('section-linhas-pepp').style.display = (currentTab === 'linhas-pepp') ? 'block' : 'none';
  
  document.getElementById('controls').style.display = 'flex';
  
  const showFilters = ['cards', 'table'].includes(currentTab);
  document.querySelectorAll('.filter-btn').forEach(function(btn) {
    btn.style.display = showFilters ? 'inline-block' : 'none';
  });
}

document.getElementById('search').addEventListener('input', render);
document.querySelectorAll('.filter-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    currentFilter = btn.dataset.filter;
    render();
  });
});
document.querySelectorAll('.tab').forEach(function(tab) {
  tab.addEventListener('click', function() {
    document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
    tab.classList.add('active');
    currentTab = tab.dataset.tab;
    render();
  });
});

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeModal();
});

render();
</script>
